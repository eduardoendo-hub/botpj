# ──────────────────────────────────────────────────────
#  Bot SDR PJ — Configurações de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────────────

# ── Aplicação ──────────────────────────────────────────
APP_ENV=production
APP_PORT=8001
APP_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# ── Admin Panel ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-por-senha-forte

# ── Anthropic / Claude ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── RD Conversas / Tallos ──────────────────────────────
# Token de autenticação da API Tallos v2
TALLOS_API_TOKEN=seu-token-tallos-aqui

# ID da conta/organização no Tallos
TALLOS_ACCOUNT_ID=seu-account-id-aqui

# Base URL da API (normalmente não precisa alterar)
TALLOS_API_BASE_URL=https://api.tallos.com.br/api/v1

# ── Notificações por Email (Gmail) ─────────────────────
# Preencher também pelo painel em /admin/email-config
GMAIL_SENDER=notificacoes.botsdrpj@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENTS=consultor@empresa.com,gerente@empresa.com

# ── Configurações do Bot ───────────────────────────────
# Liga/desliga o bot (true/false)
BOT_ENABLED=true

# Respeitar horário comercial (true = só responde fora do horário)
BOT_SCHEDULE_ENABLED=false

# Horário de atendimento do bot em dias úteis (ex: 19 a 8)
BOT_SCHEDULE_WEEKDAY_START=19
BOT_SCHEDULE_WEEKDAY_END=8

# Bot ativo no final de semana (true/false)
BOT_SCHEDULE_WEEKEND=true

# Números de teste (sempre respondem, independente de horário/status)
# Separados por vírgula
TEST_PHONE_NUMBERS=

# Tempo (horas) sem mensagem do consultor para reativar o bot automaticamente
BOT_AUTO_REACTIVATE_HOURS=12
