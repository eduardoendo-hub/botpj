# ──────────────────────────────────────────────────────────────────────────────
#  NGINX — Bot SDR PJ: bloco adicional no mesmo servidor do BOT MBA
#
#  INSTRUÇÃO: adicionar este conteúdo dentro do server block existente
#  em /etc/nginx/sites-available/botmba  (ou equivalente do seu servidor)
#
#  O BOT MBA já captura tudo em "/" → proxy para 127.0.0.1:8000
#  Basta adicionar os blocos de location abaixo ANTES do "location /" existente
# ──────────────────────────────────────────────────────────────────────────────

    # ── Mirror interno: espelha /webhook/tallos para o BOT SDR PJ ──────────
    # Declarado fora dos location blocks, dentro do server block
    location = /_mirror_pj {
        internal;
        proxy_pass         http://127.0.0.1:8001/webhook/tallos;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # ── Admin do Bot SDR PJ (acessível em /pj/admin) ───────────────────────
    location /pj/ {
        proxy_pass         http://127.0.0.1:8001/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # ── Webhook exclusivo de registro de leads PJ ───────────────────────────
    location /webhook/tallospj {
        proxy_pass         http://127.0.0.1:8001/webhook/tallospj;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # ── Webhook geral — espelha para BOT SDR PJ além do BOT MBA ────────────
    # SUBSTITUIR o location /webhook/tallos existente por este bloco
    # (ou adicionar a linha "mirror" dentro do block existente)
    location /webhook/tallos {
        mirror             /_mirror_pj;
        mirror_request_body on;
        proxy_pass         http://127.0.0.1:8000/webhook/tallos;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

# ──────────────────────────────────────────────────────────────────────────────
#  Com esta config, os endpoints ficam:
#
#  Painel Admin PJ    →  http://204.168.224.108/pj/admin
#  Webhook PJ         →  http://204.168.224.108/webhook/tallospj  (cadastro lead PJ)
#  Webhook Geral      →  http://204.168.224.108/webhook/tallos
#    ├── BOT MBA      →  127.0.0.1:8000  (resposta principal ao RD Conversas)
#    └── BOT SDR PJ   →  127.0.0.1:8001  (mirror — monitora e responde leads PJ)
#
#  O mirror é fire-and-forget: não atrasa a resposta ao RD Conversas,
#  e falhas no BOT SDR PJ não afetam o BOT MBA.
# ──────────────────────────────────────────────────────────────────────────────
